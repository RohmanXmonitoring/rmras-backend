# .env.example - Lengkap
# ============================================
# BASE CONFIGURATION
# ============================================
BASE_URL=https://api.rmras.com
PORT=3000
NODE_ENV=production

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://rmras_user:rmras_password@localhost:5432/rmras_db
DATABASE_POOL_SIZE=20
DATABASE_TIMEOUT=30000

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=3600

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_min_32_chars
JWT_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
JWT_ALGORITHM=HS256

# ============================================
# SMTP EMAIL
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@rmras.com
SMTP_REPLY_TO=support@rmras.com

# ============================================
# URLS
# ============================================
ADMIN_URL=https://admin.rmras.com
CLIENT_URL=https://client.rmras.com
WEB_URL=https://rmras.com

# ============================================
# STORAGE
# ============================================
STORAGE_PATH=./storage
UPLOAD_MAX_SIZE=100MB
SCREENSHOT_QUALITY=80
RECORDING_MAX_DURATION=3600

# ============================================
# SOCKET.IO
# ============================================
SOCKET_CORS_ORIGIN=*
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000
SOCKET_MAX_CONNECTIONS=10000

# ============================================
# FEATURES
# ============================================
ENABLE_SWAGGER=true
ENABLE_AUDIT_LOG=true
ENABLE_RATE_LIMIT=true
ENABLE_REDIS_CACHE=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_GEOFENCE=true
ENABLE_LOST_MODE=true

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_WINDOW=15
RATE_LIMIT_AUTH_MAX=5

# ============================================
# SECURITY
# ============================================
BCRYPT_ROUNDS=12
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=30
IP_WHITELIST_ENABLED=false
IP_WHITELIST=127.0.0.1,::1

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_MAX_SIZE=20m
LOG_MAX_FILES=30d
LOG_DIR=./logs

# ============================================
# MONITORING
# ============================================
HEARTBEAT_INTERVAL=30000
DEVICE_OFFLINE_TIMEOUT=60000
HEALTH_CHECK_INTERVAL=60000

# ============================================
# FILE TRANSFER
# ============================================
FILE_CHUNK_SIZE=1024 * 1024
FILE_MAX_SIZE=104857600
FILE_ALLOWED_TYPES=image/*,video/*,application/*

# ============================================
# WEBRTC
# ============================================
WEBRTC_STUN_SERVERS=stun:stun.l.google.com:19302
WEBRTC_TURN_SERVERS=turn:turn.rmras.com:3478
WEBRTC_TURN_USERNAME=rmras
WEBRTC_TURN_PASSWORD=rmras_password

# ============================================
# DATABASE BACKUP
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# ============================================
# PERFORMANCE
# ============================================
MAX_QUERY_LIMIT=1000
DEFAULT_PAGE_SIZE=20
CACHE_TTL_SHORT=60
CACHE_TTL_MEDIUM=300
CACHE_TTL_LONG=3600
