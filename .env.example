# .env.example
BASE_URL=https://api.rmras.com

# Server
PORT=3000
NODE_ENV=production

# Database
DATABASE_URL=postgresql://rmras_user:rmras_password@localhost:5432/rmras_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_password
SMTP_FROM=noreply@rmras.com

# URLs
ADMIN_URL=https://admin.rmras.com
CLIENT_URL=https://client.rmras.com

# Storage
STORAGE_PATH=./storage
UPLOAD_MAX_SIZE=100MB

# Socket
SOCKET_CORS_ORIGIN=*

# Features
ENABLE_SWAGGER=true
ENABLE_AUDIT_LOG=true
ENABLE_RATE_LIMIT=true
ENABLE_REDIS_CACHE=true

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Security
BCRYPT_ROUNDS=12
